{
  "build": {
    "command": "npm install"
  },
  "run": {
    "command": "npm start"
  },
  "env": [
    "DATABASE_URL",
    "JWT_SECRET",
    "PORT"
  ],
  "routes": [
    {
      "path": "/api/*",
      "target": "${self.target}"
    },
    {
      "path": "/health",
      "target": "${self.target}"
    },
    {
      "path": "/*",
      "target": "${self.target}"
    }
  ]
}